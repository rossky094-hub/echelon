# ========================================================
# Echelon V14-B 环境变量配置示例
# 复制为 .env 并填入真实值:
#   cp .env.example .env
# ========================================================

# -------------------------------------------------------
# LLM Provider 选择
# 三选一: anthropic | openai | ollama
# -------------------------------------------------------
LLM_PROVIDER=anthropic

# -------------------------------------------------------
# Anthropic (claude-sonnet-4-6)
# 获取 API Key: https://console.anthropic.com/
# -------------------------------------------------------
ANTHROPIC_API_KEY=

# -------------------------------------------------------
# OpenAI (gpt-4o / o3-mini)
# 获取 API Key: https://platform.openai.com/api-keys
# -------------------------------------------------------
OPENAI_API_KEY=

# 可选: 覆盖默认模型
# OPENAI_MODEL_OVERRIDE=o3-mini

# -------------------------------------------------------
# Ollama (本地运行,免费)
# 安装: https://ollama.ai/
# 启动: ollama serve
# 拉取模型: ollama pull qwen2.5:14b
# -------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:14b

# -------------------------------------------------------
# Step 1 Enrich — 多源 (推荐 s2,crossref)
# -------------------------------------------------------
# 优先级: s2 → crossref → openalex(可选,易 429)
V14B_ENRICH_PROVIDERS=s2,crossref,openalex
V14B_SKIP_S2_WITHOUT_KEY=false
# Semantic Scholar API Key: https://www.semanticscholar.org/product/api
# 限速: 1 request/second (全端点累计, 由 V14B_S2_REQUESTS_PER_SEC 控制)
SEMANTIC_SCHOLAR_API_KEY=your_s2_api_key_here
V14B_S2_REQUESTS_PER_SEC=1
V14B_S2_DELAY=1.05
V14B_S2_MAX_RETRIES=3
OPENALEX_EMAIL=your_email@example.com
CROSSREF_EMAIL=your_email@example.com

# -------------------------------------------------------
# V14-B 调试参数
# -------------------------------------------------------

# 留空跑全量,填数字只跑前 N 条 (测试用)
V14B_LIMIT=

# enrich 并发 (S2 无 key 建议 2-3)
V14B_CONCURRENCY=3
V14B_S2_DELAY=0.35
V14B_CROSSREF_DELAY=0.5

# 是否使用 MPS (Apple Silicon GPU)
V14B_USE_MPS=true

# 子图大小上限 (OOM 时减小到 2000)
V14B_SUBGRAPH_SIZE=5000

# -------------------------------------------------------
# Raw PDF cache — 外接盘 PDF 对象库
# -------------------------------------------------------
V14B_RAW_PDF_STORE_ROOT=/Volumes/LaCie/Echelon_Paper_Raw_Data
V14B_RAW_PDF_MANIFEST=/Volumes/LaCie/Echelon_Paper_Raw_Data/manifests/raw_pdf_downloads.sqlite3
V14B_SECTION_INGEST_PREFER_LOCAL_RAW_PDF=true
V14B_RAW_PDF_MAX_BYTES=209715200

# ========================================================
# 三种 Provider 配置示例
# ========================================================

# --- 方案 A: Anthropic (推荐,效果最好) ---
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# 预估成本: ~$45 全流程

# --- 方案 B: OpenAI GPT-4o ---
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# 预估成本: ~$40 全流程

# --- 方案 C: Ollama 本地 (零成本,速度慢) ---
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# # 需本地先拉模型: ollama pull qwen2.5:14b
# 预估成本: $0 (需 16GB RAM)
